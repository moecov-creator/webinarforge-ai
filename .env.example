# WebinarForge AI — Environment Configuration
# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control

# ─── Database ─────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/webinarforge_dev"

# ─── Application ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="WebinarForge AI"

# ─── Auth (Clerk) ─────────────────────────────────────────
# Get from https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# ─── Stripe ───────────────────────────────────────────────
# Get from https://stripe.com
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (create in Stripe Dashboard)
STRIPE_PRICE_STARTER_MONTHLY=""
STRIPE_PRICE_STARTER_ANNUAL=""
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_ANNUAL=""
STRIPE_PRICE_SCALE_MONTHLY=""
STRIPE_PRICE_SCALE_ANNUAL=""

# ─── AI (OpenAI) ──────────────────────────────────────────
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o"
OPENAI_TEMPERATURE="0.8"

# ─── File Storage (UploadThing) ───────────────────────────
# Get from https://uploadthing.com
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# ─── Redis / Queue ────────────────────────────────────────
# Used for background jobs and scheduled automation
REDIS_URL="redis://localhost:6379"
# Or use Upstash:
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# ─── Email (Resend) ───────────────────────────────────────
# Get from https://resend.com
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@webinarforge.ai"

# ─── Analytics (optional) ─────────────────────────────────
POSTHOG_API_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ─── Webhook Security ─────────────────────────────────────
WEBHOOK_SIGNING_SECRET="generate-a-long-random-string-here"

# ─── Admin ────────────────────────────────────────────────
ADMIN_EMAIL="admin@webinarforge.ai"

# ─── Feature Flags ────────────────────────────────────────
NEXT_PUBLIC_ENABLE_AI_CLOSER="false"
NEXT_PUBLIC_ENABLE_CLONER="false"
NEXT_PUBLIC_ENABLE_MARKETPLACE="false"
NEXT_PUBLIC_MAINTENANCE_MODE="false"

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_AI_REQUESTS_PER_MINUTE="10"

# ─── Encryption ───────────────────────────────────────────
# 32-byte key for encrypting provider credentials at rest
ENCRYPTION_KEY="generate-32-char-key-here-abcdefg"
