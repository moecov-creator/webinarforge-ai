# WebinarForge AI — Environment Configuration
# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control

# ─── Database ─────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/webinarforge_dev"

# ─── Application ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="WebinarForge AI"

# ─── Auth (Clerk) ─────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# ─── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs — monthly subscriptions
STRIPE_PRICE_STARTER_MONTHLY=""
STRIPE_PRICE_STARTER_ANNUAL=""
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_ANNUAL=""
STRIPE_PRICE_SCALE_MONTHLY=""
STRIPE_PRICE_SCALE_ANNUAL=""

# ─── Early Bird Special ───────────────────────────────────
# Create ONE-TIME prices in Stripe Dashboard for each
STRIPE_PRICE_EARLY_BIRD=""
STRIPE_PRICE_UPSELL_TEMPLATES=""
STRIPE_PRICE_UPSELL_ONBOARDING=""
STRIPE_PRICE_UPSELL_FULLFUNNEL=""

# Early Bird Config
NEXT_PUBLIC_EARLY_BIRD_END="2026-04-16T23:59:59"
NEXT_PUBLIC_EARLY_BIRD_TOTAL_SPOTS="500"
NEXT_PUBLIC_EARLY_BIRD_PRICE="49"

# ─── AI (OpenAI) ──────────────────────────────────────────
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o"
OPENAI_TEMPERATURE="0.8"

# ─── File Storage (UploadThing) ───────────────────────────
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# ─── Redis / Queue ────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# ─── Email (Resend) ───────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@webinarforge.ai"
RESEND_EARLY_BIRD_FROM="marcus@webinarforge.ai"

# ─── Analytics ────────────────────────────────────────────
POSTHOG_API_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ─── Webhook Security ─────────────────────────────────────
WEBHOOK_SIGNING_SECRET="generate-a-long-random-string-here"

# ─── Admin ────────────────────────────────────────────────
ADMIN_EMAIL="admin@webinarforge.ai"

# ─── Feature Flags ────────────────────────────────────────
NEXT_PUBLIC_ENABLE_AI_CLOSER="false"
NEXT_PUBLIC_ENABLE_CLONER="false"
NEXT_PUBLIC_ENABLE_MARKETPLACE="false"
NEXT_PUBLIC_MAINTENANCE_MODE="false"
NEXT_PUBLIC_ENABLE_EARLY_BIRD="true"
NEXT_PUBLIC_ENABLE_UPSELLS="true"

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_AI_REQUESTS_PER_MINUTE="10"

# ─── Encryption ───────────────────────────────────────────
ENCRYPTION_KEY="generate-32-char-key-here-abcdefg"
